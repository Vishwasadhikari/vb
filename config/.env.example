# Copy this file to `.env` in the same folder and fill in your key.
#
# This backend uses Groq for Roblox Lua script generation.
# Get your key at https://console.groq.com/keys

GROQ_API_KEY="gsk-your-groq-api-key-here"

# Optional: model (default: llama-3.3-70b-versatile)
# GROQ_MODEL="llama-3.3-70b-versatile"
